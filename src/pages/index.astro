---
import BaseLayout from '../layouts/BaseLayout.astro';
import AnnouncementBar from '../components/AnnouncementBar.astro';
import SiteHeader from '../components/SiteHeader.astro';
import HeroSection from '../components/HeroSection.astro';
import WhoWeAreSection from '../components/WhoWeAreSection.astro';
import AboutSection from '../components/AboutSection.astro';
import ServicesSection from '../components/ServicesSection.astro';
import BenefitsSection from '../components/BenefitsSection.astro';
import Footer from '../components/Footer.astro';
import { siteConfig } from '../config/site';
const { socialLinks } = siteConfig;
---

<BaseLayout
  title="Mountain Green – Cannabis-Rohstoffe & Extrakte"
  description="Mountain Green ist ein vertikal integrierter Produzent hochwertiger Cannabis-Rohstoffe und Extrakte für Medizin, Industrie und Konsumprodukte."
>
  <div class="sticky top-0 z-40">
    {siteConfig.announcementBar.enabled && (
      <AnnouncementBar text={siteConfig.announcementBar.text} />
    )}
    <SiteHeader
      logoSrc="/images/logo/mountaingreen_logo.webp"
      logoAlt="Mountain Green Logo"
      menuItems={[{ label: 'Login', href: 'https://app.mountaingreen.at' }, { label: 'Kontakt', href: '/kontakt' }]}
    />
  </div>

  <main>
    <HeroSection
      headline="Premium Hanfanbau aus dem Gurktal"
      subline="Hochwertige Cannabisrohstoffe und Extrakte – vom Anbau bis zum fertigen Produkt."
      images={[
        { src: '/images/hero1.webp', alt: 'Cannabis-Ernte im Gurktal bei Sonnenuntergang' },
        { src: '/images/hero2.webp', alt: 'Blick über Cannabis-Felder mit Bergpanorama' },
      ]}
    />

    <WhoWeAreSection
      heading="Mountain Green"
      text="Produzent hochwertiger Cannabisrohstoffe und Extrakte für Medizin, Industrie und Konsumprodukte – mit integrierter Wertschöpfung vom Anbau bis zu marktfähigen Produkten."
      ctaText="Mehr erfahren"
      ctaHref="#leistungen"
    />

    <AboutSection
      heading="Kompetente Wertschöpfungskette"
      text="Mountain Green arbeitet mit spezialisierten Partnern entlang der gesamten Wertschöpfungskette der Cannabispflanze. Der Anbau und die Extraktion erfolgen gemeinsam mit erfahrenen Produzenten, die moderne Agrartechnologie mit schonender CO₂-Extraktion verbinden. Für die Entwicklung marktfähiger Produkte kooperieren wir mit Herstellern, die natürliche Wirkstoffe mit moderner Forschung kombinieren und daraus hochwertige Gesundheits- und Kosmetikprodukte entwickeln."
      locationLabel="Standort Gurktal, Kärnten"
      locationDetail="Der Standort im Gurktal bietet ideale klimatische Bedingungen für hochwertigen Cannabis-Anbau."
      ctaText="Kontakt aufnehmen"
      ctaHref="/kontakt"
    />

    <ServicesSection
      heading="Integrierte Cannabis-Produktion"
      ctaText="Jetzt Mountain Green Partner werden"
      ctaHref="/kontakt"
      services={[
        {
          icon: "sprout",
          title: "Anbau",
          description: "Professioneller Cannabis-Anbau unter kontrollierten Bedingungen mit Fokus auf hohe Pflanzenqualität, stabile Erträge und vollständige Rückverfolgbarkeit. Moderne Agrartechnologie, sorgfältige Sortenauswahl und standardisierte Anbauprozesse bilden die Grundlage für hochwertige Biomasse.",
          imageSrc: "/images/Anbau1.webp",
          imageAlt: "Cannabis-Anbau bei Mountain Green"
        },
        {
          icon: "flask",
          title: "Veredelung",
          description: "Schonende Verarbeitung der geernteten Biomasse zu hochwertigen Cannabis-Extrakten und Rohstoffen. Moderne CO₂-Extraktion, präzise Laboranalysen sowie standardisierte Produktionsprozesse gewährleisten gleichbleibende Qualität nach internationalen Qualitätsstandards.",
          imageSrc: "/images/Veredelung1.webp",
          imageAlt: "Veredelung und Extraktion bei Mountain Green"
        },
        {
          icon: "package",
          title: "Produktion & Verkauf",
          description: "Entwicklung und Herstellung marktfähiger Cannabisprodukte für Handel, Gesundheitsbereich und Markenlösungen. Produktion nach GMP- und ISO-konformen Qualitätsstandards sowie Vertrieb über Partnernetzwerke und White-Label-Programme.",
          imageSrc: "/images/Produktion1.webp",
          imageAlt: "Fertige Cannabis-Produkte von Mountain Green"
        }
      ]}
    />

    <BenefitsSection
      sectionHeading="Erfahren Sie, wie Sie an der Cannabis-Wertschöpfung teilnehmen können"
      b2b={{
        badge: "B2B",
        heading: "White-Label & Partnerlösungen",
        text: "Unternehmen erhalten Zugang zu hochwertiger Cannabis-Biomasse und standardisierten Extrakten. Mountain Green ermöglicht Partnern den schnellen Einstieg in den Cannabinoid-Markt mit fertigen Produktlösungen.",
        features: [
          "Hochwertige Cannabis-Biomasse",
          "Standardisierte Extrakte",
          "White-Label-Produktion unter eigener Marke",
          "Schneller Markteinstieg"
        ],
        ctaText: "Partnerangebot anfragen",
        ctaHref: "/kontakt",
        ctaSubtext: "White-Label Produktion ab kleinen Stückzahlen"
      }}
      b2c={{
        badge: "B2C",
        heading: "Qualität für Endverbraucher",
        text: "Konsumenten erhalten geprüfte Cannabisprodukte mit nachvollziehbarer Herkunft. Natürliche Pflanzenstoffe kombiniert mit moderner Verarbeitungstechnologie.",
        features: [
          "Geprüfte Produkte mit Herkunftsnachweis",
          "Natürliche Pflanzenstoffe",
          "Moderne Verarbeitungstechnologie",
          "Wohlbefinden, Balance und Lifestyle"
        ],
        ctaText: "Produkte entdecken",
        ctaHref: "/kontakt",
        ctaSubtext: "Direkt vom Produzenten"
      }}
    />
  </main>

  <Footer
    companyName="Mountain Green"
    imprintHref="/impressum"
    imprintLabel="Impressum"
    socialLinks={socialLinks}
  />
</BaseLayout>
