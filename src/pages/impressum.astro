---
import BaseLayout from '../layouts/BaseLayout.astro';
import AnnouncementBar from '../components/AnnouncementBar.astro';
import SiteHeader from '../components/SiteHeader.astro';
import Footer from '../components/Footer.astro';
import { siteConfig } from '../config/site';
const { socialLinks } = siteConfig;
---

<BaseLayout
  title="Impressum – Mountain Green GmbH"
  description="Impressum der Mountain Green GmbH gemäß §5 ECG, §14 UGB, §63 GewO und §25 Mediengesetz."
>
  <div class="sticky top-0 z-40">
    {siteConfig.announcementBar.enabled && (
      <AnnouncementBar text={siteConfig.announcementBar.text} />
    )}
    <SiteHeader
      logoSrc="/images/logo/mountaingreen_logo.webp"
      logoAlt="Mountain Green Logo"
      menuItems={[{ label: 'Login', href: 'https://app.mountaingreen.at' }, { label: 'Kontakt', href: '/kontakt' }]}
    />
  </div>

  <main class="py-24 sm:py-32">
    <div class="mx-auto max-w-3xl px-6 sm:px-8 lg:px-12">
      <div data-animate="up">
        <h1
          class="font-heading text-3xl font-bold tracking-tight text-green-800 sm:text-4xl"
          style="letter-spacing: -0.02em;"
        >
          Impressum
        </h1>

        <div class="mt-10 space-y-10 text-base text-neutral-700" style="line-height: 1.7;">
          <section>
            <p>
              Informationspflicht laut §5 E-Commerce Gesetz, §14 Unternehmensgesetzbuch, §63
              Gewerbeordnung und Offenlegungspflicht laut §25 Mediengesetz
            </p>
            <p class="mt-4">
              <strong class="text-green-800">Mountain Green GmbH</strong><br />
              Zwatzhof 8<br />
              9362 Grades, Kärnten<br /><br />
              Österreich
            </p>
          </section>

          <section>
            <p>
              <strong class="text-green-800">Firmenbuchnummer:</strong> FN 591530 y<br />
              <strong class="text-green-800">Vertreten durch:</strong> Dietmar Wurzer
            </p>
          </section>

          <section>
            <h2 class="font-heading text-xl font-semibold text-green-800">Kontakt</h2>
            <p class="mt-2">
              E-Mail: <a href="mailto:office@mountaingreen.at" class="text-green-600 underline decoration-green-600/30 underline-offset-2 hover:decoration-green-600">office@mountaingreen.at</a>
            </p>
          </section>

          <section>
            <p>
              <strong class="text-green-800">Umsatzsteuer-ID:</strong> ATU78748018
            </p>
          </section>

          <section>
            <h2 class="font-heading text-xl font-semibold text-green-800">Redaktionell verantwortlich</h2>
            <p class="mt-2">
              Dietmar Wurzer<br />
              Zwatzhof 8<br />
              9362 Grades<br /><br />
              Österreich
            </p>
          </section>

          <section>
            <h2 class="font-heading text-xl font-semibold text-green-800">EU-Streitschlichtung</h2>
            <p class="mt-2">
              Die Europäische Kommission stellt eine Plattform zur Online-Streitbeilegung (OS) bereit:
              <a href="https://ec.europa.eu/consumers/odr/" target="_blank" rel="noopener noreferrer" class="text-green-600 underline decoration-green-600/30 underline-offset-2 hover:decoration-green-600">https://ec.europa.eu/consumers/odr/</a>.<br />
              Unsere E-Mail-Adresse finden Sie oben im Impressum.
            </p>
          </section>

          <section>
            <h2 class="font-heading text-xl font-semibold text-green-800">Verbraucher­streit­beilegung/Universal­schlichtungs­stelle</h2>
            <p class="mt-2">
              Wir sind nicht bereit oder verpflichtet, an Streitbeilegungsverfahren vor einer
              Verbraucherschlichtungsstelle teilzunehmen.
            </p>
          </section>

          <section>
            <p>
              Ist Käufer/in ein/e Verbraucher/in, kann diese/r nur beim Gericht ihres/seines
              Wohnsitzes, Aufenthaltsortes oder Beschäftigungsortes verklagt werden. In allen
              anderen Fällen ist ausschließlicher Gerichtsstand das Bezirksgericht Villach bzw.
              das Landesgericht Klagenfurt am Wörthersee, Österreich. Erfüllungsort ist
              9220 Velden am Wörthersee, Österreich.
            </p>
          </section>
        </div>
      </div>
    </div>
  </main>

  <Footer
    companyName="Mountain Green"
    imprintHref="/impressum"
    imprintLabel="Impressum"
    socialLinks={socialLinks}
  />
</BaseLayout>
