---
import BaseLayout from '../layouts/BaseLayout.astro';
import AnnouncementBar from '../components/AnnouncementBar.astro';
import SiteHeader from '../components/SiteHeader.astro';
import Footer from '../components/Footer.astro';
import { siteConfig } from '../config/site';
const { socialLinks } = siteConfig;
---

<BaseLayout
  title="Kontakt – Mountain Green"
  description="Nehmen Sie Kontakt mit Mountain Green auf. Wir freuen uns auf Ihre Anfrage zu Cannabis-Rohstoffen, Extrakten und Partnerlösungen."
>
  {siteConfig.announcementBar.enabled && (
    <AnnouncementBar text={siteConfig.announcementBar.text} />
  )}

  <SiteHeader
    logoSrc="/images/logo/mountaingreen_logo.webp"
    logoAlt="Mountain Green Logo"
    menuItems={[{ label: 'Kontakt', href: '/kontakt' }]}
  />

  <main class="py-24 sm:py-32">
    <div class="mx-auto max-w-3xl px-6 sm:px-8 lg:px-12">
      <div class="text-center" data-animate="up">
        <span class="mb-4 inline-block rounded-full bg-green-100 px-4 py-1.5 font-body text-xs font-medium uppercase tracking-widest text-green-800">
          Kontakt
        </span>
        <h1
          class="mt-2 font-heading text-3xl font-bold tracking-tight text-green-800 sm:text-4xl"
          style="letter-spacing: -0.02em;"
        >
          Sprechen Sie mit uns
        </h1>
        <p class="mt-4 text-lg text-neutral-700" style="line-height: 1.7;">
          Ob Partnerschaft, Produktanfrage oder allgemeine Fragen – wir sind für Sie da.
        </p>
      </div>

      <div class="mt-16 grid gap-8 sm:grid-cols-2" data-animate="up" data-delay="1">
        <!-- Kontaktdaten -->
        <div class="rounded-2xl border border-green-100 bg-green-50 p-8 shadow-sm">
          <h2 class="font-heading text-xl font-semibold text-green-800">Kontaktdaten</h2>
          <ul class="mt-6 space-y-4 text-neutral-700" role="list">
            <li class="flex items-start gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              <span>office@mountaingreen.at</span>
            </li>
            <li class="flex items-start gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              <span>+43 (0) 463 123 456</span>
            </li>
            <li class="flex items-start gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0" aria-hidden="true"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/></svg>
              <span>Gurktal, Kärnten<br/>Österreich</span>
            </li>
          </ul>
        </div>

        <!-- Öffnungszeiten -->
        <div class="rounded-2xl border border-green-100 bg-green-50 p-8 shadow-sm">
          <h2 class="font-heading text-xl font-semibold text-green-800">Erreichbarkeit</h2>
          <ul class="mt-6 space-y-3 text-neutral-700" role="list">
            <li class="flex justify-between">
              <span>Mo – Fr</span>
              <span class="font-medium">08:00 – 17:00</span>
            </li>
            <li class="flex justify-between">
              <span>Samstag</span>
              <span class="font-medium">Nach Vereinbarung</span>
            </li>
            <li class="flex justify-between">
              <span>Sonntag</span>
              <span class="font-medium">Geschlossen</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </main>

  <Footer
    companyName="Mountain Green"
    imprintHref="/impressum"
    imprintLabel="Impressum"
    socialLinks={socialLinks}
  />
</BaseLayout>
