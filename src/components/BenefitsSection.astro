---
interface BenefitColumn {
  badge: string;
  heading: string;
  text: string;
  features: string[];
}

interface Props {
  sectionHeading: string;
  b2b: BenefitColumn;
  b2c: BenefitColumn;
  ctaText?: string;
  ctaHref?: string;
}

const { sectionHeading, b2b, b2c, ctaText, ctaHref } = Astro.props;
---

<section aria-labelledby="benefits-heading" class="bg-[#F7F7F5] py-24 sm:py-32">
  <div class="mx-auto max-w-6xl px-6 sm:px-8 lg:px-12">
    <!-- Section Header -->
    <div data-animate="up" class="text-center">
      <span class="mb-4 inline-block rounded-full bg-green-100 px-4 py-1.5 font-body text-xs font-medium uppercase tracking-widest text-green-800">
        Ihr Nutzen
      </span>
      <h2
        id="benefits-heading"
        class="mt-2 font-heading text-[28px] font-normal italic tracking-tight text-green-800 sm:text-[32px]"
        style="letter-spacing: -0.01em;"
      >
        {sectionHeading}
      </h2>
    </div>

    <!-- Two Column Layout -->
    <div class="mt-16 grid gap-8 lg:grid-cols-2">
      {[b2b, b2c].map((col, i) => (
        <div data-animate={i === 0 ? 'left' : 'right'} data-delay={String(i + 1)}>
          <div class="h-full rounded-2xl border border-green-100 bg-green-50 p-8 sm:p-10">
            <span class="inline-block rounded-full bg-green-600 px-3 py-1 font-body text-xs font-medium uppercase tracking-widest text-white">
              {col.badge}
            </span>
            <h3 class="mt-4 font-heading text-2xl font-semibold text-green-800">
              {col.heading}
            </h3>
            <p class="mt-4 text-base text-neutral-700" style="line-height: 1.7;">
              {col.text}
            </p>
            <ul class="mt-6 space-y-3" role="list">
              {col.features.map((feature) => (
                <li class="flex items-start gap-3 text-neutral-700">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#054027" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0" aria-hidden="true">
                    <path d="M20 6 9 17l-5-5"/>
                  </svg>
                  <span>{feature}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>

    <!-- CTA -->
    {ctaText && ctaHref && (
      <div class="mt-16 text-center" data-animate="up">
        <a
          href={ctaHref}
          class="inline-flex items-center gap-2 rounded-xl bg-green-600 px-8 py-4 font-body text-base font-bold text-white shadow-sm transition-all duration-200 hover:bg-green-800 hover:shadow-md focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-green-600"
        >
          {ctaText}
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
        </a>
      </div>
    )}
  </div>
</section>
