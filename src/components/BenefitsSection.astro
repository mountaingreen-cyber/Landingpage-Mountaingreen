---
interface BenefitColumn {
  badge: string;
  heading: string;
  text: string;
  features: string[];
}

interface Props {
  sectionHeading: string;
  b2b: BenefitColumn;
  b2c: BenefitColumn;
}

const { sectionHeading, b2b, b2c } = Astro.props;
---

<section aria-labelledby="benefits-heading" class="bg-white py-24 sm:py-32">
  <div class="mx-auto max-w-6xl px-6 sm:px-8 lg:px-12">
    <!-- Section Header -->
    <div class="text-center">
      <span class="mb-4 inline-block rounded-full bg-green-100 px-4 py-1.5 font-body text-xs font-medium uppercase tracking-widest text-green-800">
        Ihr Nutzen
      </span>
      <h2
        id="benefits-heading"
        class="mt-2 font-heading text-3xl font-bold tracking-tight text-green-800 sm:text-4xl"
        style="letter-spacing: -0.02em;"
      >
        {sectionHeading}
      </h2>
    </div>

    <!-- Two Column Layout -->
    <div class="mt-16 grid gap-8 lg:grid-cols-2">
      {[b2b, b2c].map((col) => (
        <div class="rounded-2xl border border-green-100 bg-green-50 p-8 sm:p-10">
          <span class="inline-block rounded-full bg-green-600 px-3 py-1 font-body text-xs font-medium uppercase tracking-widest text-white">
            {col.badge}
          </span>
          <h3 class="mt-4 font-heading text-2xl font-semibold text-green-800">
            {col.heading}
          </h3>
          <p class="mt-4 text-base text-neutral-700" style="line-height: 1.7;">
            {col.text}
          </p>
          <ul class="mt-6 space-y-3" role="list">
            {col.features.map((feature) => (
              <li class="flex items-start gap-3 text-neutral-700">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0" aria-hidden="true">
                  <path d="M20 6 9 17l-5-5"/>
                </svg>
                <span>{feature}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
