---
interface MenuItem {
  label: string;
  href: string;
}

interface Props {
  logoSrc: string;
  logoAlt: string;
  menuItems: MenuItem[];
}

const { logoSrc, logoAlt, menuItems } = Astro.props;
---

<header id="site-header" class="bg-[#F7F7F5]/95 backdrop-blur-sm shadow-sm">
  <div class="header-inner relative mx-auto flex max-w-6xl items-center justify-center px-6 sm:px-8 lg:px-12">
    <a href="/" class="block">
      <img
        src={logoSrc}
        alt={logoAlt}
        width="160"
        height="160"
        class="header-logo object-contain"
        id="header-logo"
      />
    </a>

    <button
      id="menu-toggle"
      type="button"
      class="absolute right-6 flex h-10 w-10 items-center justify-center rounded-lg text-green-800 transition-colors hover:bg-green-50 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-green-600 sm:right-8 lg:right-12"
      aria-label="Menü öffnen"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg id="icon-menu" xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="4" x2="20" y1="6" y2="6"/>
        <line x1="4" x2="20" y1="12" y2="12"/>
        <line x1="4" x2="20" y1="18" y2="18"/>
      </svg>
      <svg id="icon-close" class="hidden" xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M18 6 6 18"/>
        <path d="m6 6 12 12"/>
      </svg>
    </button>
  </div>

  <nav
    id="mobile-menu"
    class="hidden border-t border-green-100 bg-[#F7F7F5]"
    aria-label="Hauptnavigation"
  >
    <div class="mx-auto max-w-6xl px-6 sm:px-8 lg:px-12">
      <ul class="flex flex-col items-end divide-y divide-green-50" role="list">
        {menuItems.map((item) => (
          <li class="w-auto">
            <a
              href={item.href}
              class="block py-4 pl-8 text-base font-medium text-green-800 transition-colors hover:text-green-600"
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </nav>
</header>

<style>
  .header-inner {
    padding-top: 1rem;
    padding-bottom: 1rem;
    transition: padding 0.3s ease;
  }
  .header-logo {
    height: 160px;
    width: 160px;
    transition: height 0.3s ease, width 0.3s ease;
  }
  #site-header.is-scrolled .header-inner {
    padding-top: 0.25rem;
    padding-bottom: 0.25rem;
  }
  #site-header.is-scrolled .header-logo {
    height: 48px;
    width: 48px;
  }
</style>

<script>
  const toggle = document.getElementById('menu-toggle')!;
  const menu = document.getElementById('mobile-menu')!;
  const iconMenu = document.getElementById('icon-menu')!;
  const iconClose = document.getElementById('icon-close')!;

  toggle.addEventListener('click', () => {
    const isOpen = menu.classList.toggle('hidden');
    toggle.setAttribute('aria-expanded', String(!isOpen));
    iconMenu.classList.toggle('hidden');
    iconClose.classList.toggle('hidden');
  });

  const header = document.getElementById('site-header')!;
  const bar = document.getElementById('announcement-bar');

  // Cache bar height once before any animation
  const barHeight = bar ? bar.offsetHeight : 0;

  let ticking = false;
  let isScrolled = false;
  let barHidden = false;

  window.addEventListener('scroll', () => {
    if (ticking) return;
    ticking = true;
    requestAnimationFrame(() => {
      const y = window.scrollY;
      const shouldScrolled = y > 40;
      const shouldBarHidden = y > 10;

      if (shouldScrolled !== isScrolled) {
        header.classList.toggle('is-scrolled', shouldScrolled);
        isScrolled = shouldScrolled;
      }

      if (bar && shouldBarHidden !== barHidden) {
        bar.style.height = shouldBarHidden ? '0' : `${barHeight}px`;
        bar.style.opacity = shouldBarHidden ? '0' : '1';
        barHidden = shouldBarHidden;
      }

      ticking = false;
    });
  }, { passive: true });
</script>
