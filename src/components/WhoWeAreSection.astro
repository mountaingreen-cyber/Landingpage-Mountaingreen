---
interface Props {
  heading: string;
  text: string;
  ctaText: string;
  ctaHref: string;
}

const { heading, text, ctaText, ctaHref } = Astro.props;
---

<section aria-labelledby="whoweare-heading" class="bg-neutral-50 py-24 sm:py-32">
  <div class="mx-auto max-w-6xl px-6 sm:px-8 lg:px-12">
    <div class="mx-auto max-w-3xl text-center" data-animate="up">
      <span class="mb-4 inline-block rounded-full bg-green-600 px-4 py-1.5 font-body text-xs font-medium uppercase tracking-widest text-white">
        ANBAU · VERARBEITUNG · QUALITÄT
      </span>
      <h2
        id="whoweare-heading"
        class="mt-2 font-heading text-3xl font-bold tracking-tight text-green-800 sm:text-4xl"
        style="letter-spacing: -0.02em;"
      >
        {heading}
      </h2>
      <p class="mt-6 text-lg leading-relaxed text-neutral-700" style="line-height: 1.7;">
        {text}
      </p>
      <a
        href={ctaHref}
        class="mt-8 inline-flex items-center gap-2 rounded-xl bg-green-600 px-8 py-4 font-body text-base font-medium text-white shadow-sm transition-all duration-200 hover:bg-green-800 hover:shadow-md focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-green-600"
      >
        {ctaText}
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="m9 18 6-6-6-6"/>
        </svg>
      </a>
    </div>
  </div>
</section>
