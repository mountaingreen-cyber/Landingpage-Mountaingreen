---
interface Props {
  heading: string;
  text: string;
  locationLabel: string;
  locationDetail: string;
}

const { heading, text, locationLabel, locationDetail } = Astro.props;
---

<section aria-labelledby="about-heading" class="bg-white py-24 sm:py-32">
  <div class="mx-auto max-w-6xl px-6 sm:px-8 lg:px-12">
    <div class="grid gap-12 lg:grid-cols-2 lg:gap-16 items-center">
      <!-- Text Column -->
      <div>
        <span class="mb-4 inline-block rounded-full bg-green-100 px-4 py-1.5 font-body text-xs font-medium uppercase tracking-widest text-green-800">
          Über uns
        </span>
        <h2
          id="about-heading"
          class="mt-2 font-heading text-3xl font-bold tracking-tight text-green-800 sm:text-4xl"
          style="letter-spacing: -0.02em;"
        >
          {heading}
        </h2>
        <p class="mt-6 text-lg leading-relaxed text-neutral-700" style="line-height: 1.7;">
          {text}
        </p>
      </div>

      <!-- Location Card -->
      <div class="rounded-2xl border border-green-100 bg-green-50 p-8 shadow-sm">
        <div class="flex items-start gap-4">
          <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-green-600 text-white" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
          </div>
          <div>
            <h3 class="font-heading text-lg font-semibold text-green-800">
              {locationLabel}
            </h3>
            <p class="mt-1 text-base text-neutral-700" style="line-height: 1.7;">
              {locationDetail}
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
