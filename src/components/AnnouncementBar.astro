---
interface Props {
  text: string;
}

const { text } = Astro.props;
---

<div
  id="announcement-bar"
  class="overflow-hidden bg-green-950 text-center text-sm font-medium text-white"
  role="banner"
>
  <div class="mx-auto max-w-6xl px-6 py-2">
    {text}
  </div>
</div>

<style>
  #announcement-bar {
    transition: height 0.35s ease, opacity 0.35s ease;
  }
</style>
