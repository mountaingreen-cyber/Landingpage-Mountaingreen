---
interface Props {
  headline: string;
  subline: string;
  images: { src: string; alt: string }[];
}

const { headline, subline, images } = Astro.props;
---

<section aria-labelledby="hero-heading" class="relative h-[85vh] min-h-[500px] overflow-hidden">
  <!-- Slideshow Images -->
  {images.map((img, i) => (
    <img
      src={img.src}
      alt={img.alt}
      class:list={[
        'hero-slide absolute inset-0 h-full w-full object-cover transition-opacity duration-1000',
        i === 0 ? 'opacity-100' : 'opacity-0',
      ]}
      data-slide={i}
      fetchpriority={i === 0 ? 'high' : undefined}
      loading={i === 0 ? 'eager' : 'lazy'}
      decoding={i === 0 ? 'sync' : 'async'}
    />
  ))}

  <!-- Dark overlay for text readability -->
  <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/30 to-black/10" aria-hidden="true"></div>

  <!-- Text Overlay -->
  <div class="absolute inset-0 flex items-end justify-center pb-24 sm:items-center sm:pb-0">
    <div class="px-6 text-center">
      <h1
        id="hero-heading"
        class="font-heading text-4xl font-bold leading-tight text-amber-50 drop-shadow-lg sm:text-5xl lg:text-6xl"
        style="letter-spacing: -0.01em; text-shadow: 0 2px 16px rgba(0,0,0,0.5);"
      >
        {headline}
      </h1>
      <p
        class="mx-auto mt-4 max-w-xl text-lg text-amber-100/90 drop-shadow-md sm:text-xl"
        style="text-shadow: 0 1px 8px rgba(0,0,0,0.5); line-height: 1.7;"
      >
        {subline}
      </p>
    </div>
  </div>
</section>

<script>
  const slides = document.querySelectorAll<HTMLImageElement>('.hero-slide');
  if (slides.length > 1) {
    let current = 0;
    setInterval(() => {
      slides[current].classList.replace('opacity-100', 'opacity-0');
      current = (current + 1) % slides.length;
      slides[current].classList.replace('opacity-0', 'opacity-100');
    }, 5000);
  }
</script>
