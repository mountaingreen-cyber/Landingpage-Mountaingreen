---
interface ServiceCard {
  icon: string;
  title: string;
  description: string;
  imagePlaceholder: string;
}

interface Props {
  heading: string;
  services: ServiceCard[];
  ctaText: string;
  ctaHref: string;
}

const { heading, services, ctaText, ctaHref } = Astro.props;

const icons: Record<string, string> = {
  sprout: '<path d="M7 20h10"/><path d="M10 20c5.5-2.5.8-6.4 3-10"/><path d="M9.5 9.4c1.1.8 1.8 2.2 2.3 3.7-2 .4-3.5.4-4.8-.3-1.2-.6-2.3-1.9-3-4.2 2.8-.5 4.4 0 5.5.8z"/><path d="M14.1 6a7 7 0 0 0-1.1 4c1.9-.1 3.3-.6 4.3-1.4 1-1 1.6-2.3 1.7-4.6-2.7.1-4 1-4.9 2z"/>',
  flask: '<path d="M10 2v7.527a2 2 0 0 1-.211.896L4.72 20.55a1 1 0 0 0 .9 1.45h12.76a1 1 0 0 0 .9-1.45l-5.069-10.127A2 2 0 0 1 14 9.527V2"/><path d="M8.5 2h7"/><path d="M7 16h10"/>',
  package: '<path d="M11 21.73a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73z"/><path d="M12 22V12"/><path d="m3.3 7 7.703 4.734a2 2 0 0 0 1.994 0L20.7 7"/><path d="m7.5 4.27 9 5.15"/>',
};
---

<section aria-labelledby="services-heading" id="leistungen" class="bg-neutral-50 py-24 sm:py-32">
  <div class="mx-auto max-w-6xl px-6 sm:px-8 lg:px-12">
    <!-- Section Header -->
    <div data-animate="up" class="text-center">
      <span class="mb-4 inline-block rounded-full bg-green-100 px-4 py-1.5 font-body text-xs font-medium uppercase tracking-widest text-green-800">
        Leistungen
      </span>
      <h2
        id="services-heading"
        class="mt-2 font-heading text-[32px] font-normal tracking-tight text-green-800 sm:text-[38px]"
        style="letter-spacing: -0.01em;"
      >
        {heading}
      </h2>
    </div>

    <!-- Staggered 2-Column Cards -->
    <div class="mt-16 space-y-12">
      {services.map((service, i) => (
        <div
          data-animate={i % 2 === 0 ? 'left' : 'right'}
          class:list={[
            'grid items-center gap-8 lg:grid-cols-2 lg:gap-12',
            i % 2 !== 0 && 'lg:direction-rtl',
          ]}
        >
          <!-- Text Card -->
          <article class:list={['rounded-2xl bg-[#F7F7F5] p-8 shadow-sm', i % 2 !== 0 && 'lg:order-2']}>
            <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-green-100 text-green-600" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={icons[service.icon] || icons.package} />
            </div>
            <h3 class="mt-6 font-heading text-xl font-semibold text-green-800">
              {service.title}
            </h3>
            <p class="mt-3 text-base text-neutral-700" style="line-height: 1.7;">
              {service.description}
            </p>
          </article>

          <!-- Image Placeholder -->
          <div class:list={['flex aspect-[4/3] items-center justify-center rounded-2xl border-2 border-dashed border-green-200 bg-green-50/50', i % 2 !== 0 && 'lg:order-1']}>
            <div class="text-center text-green-600/50">
              <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="mx-auto" aria-hidden="true">
                <rect width="18" height="18" x="3" y="3" rx="2" ry="2"/>
                <circle cx="9" cy="9" r="2"/>
                <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/>
              </svg>
              <p class="mt-2 text-sm font-medium">{service.imagePlaceholder}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="mt-16 text-center" data-animate="up">
      <a
        href={ctaHref}
        class="inline-flex items-center gap-2 rounded-xl bg-green-600 px-8 py-4 font-accent text-sm italic text-white shadow-sm transition-all duration-200 hover:bg-green-800 hover:shadow-md focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-green-600"
      >
        {ctaText}
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="m9 18 6-6-6-6"/>
        </svg>
      </a>
    </div>
  </div>
</section>
