---
interface Props {
  companyName: string;
  imprintHref: string;
  imprintLabel: string;
}

const { companyName, imprintHref, imprintLabel } = Astro.props;
const currentYear = new Date().getFullYear();
---

<footer class="bg-green-950 py-12" role="contentinfo">
  <div class="mx-auto max-w-6xl px-6 sm:px-8 lg:px-12">
    <div class="flex flex-col items-center justify-between gap-6 sm:flex-row">
      <!-- Company -->
      <div class="flex items-center gap-3">
        <img
          src="/images/logo/mountaingreen_logo.webp"
          alt={`${companyName} Logo`}
          width="32"
          height="32"
          class="h-8 w-auto brightness-0 invert"
          loading="lazy"
        />
        <span class="font-heading text-sm font-semibold text-green-100">
          {companyName}
        </span>
      </div>

      <!-- Links -->
      <nav aria-label="Footer-Navigation">
        <ul class="flex gap-6" role="list">
          <li>
            <a
              href={imprintHref}
              class="text-sm text-green-100/70 transition-colors duration-200 hover:text-white focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-green-100"
            >
              {imprintLabel}
            </a>
          </li>
        </ul>
      </nav>

      <!-- Copyright -->
      <p class="text-sm text-green-100/50">
        &copy; {currentYear} {companyName}
      </p>
    </div>
  </div>
</footer>
